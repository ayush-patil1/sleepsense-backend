# Example environment variables for testing
# Copy this to .env and update with your actual credentials

# For testing without real Fitbit credentials, you can use:
FITBIT_CLIENT_ID=test_client_id
FITBIT_CLIENT_SECRET=test_client_secret
FITBIT_REDIRECT_URI=http://localhost:8000/api/auth/fitbit/callback

# Generate a secure JWT secret:
SECRET_KEY=test_secret_key_for_development_only
